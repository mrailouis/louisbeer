{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "louiswebsite",
  "main": "custom-worker.ts",
  "compatibility_date": "2026-05-02",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
